# Upster environment configuration.
# Copy this file to .env and fill in the values for your machine.

# Host directory mounted into the container at /workspaces.
# It must contain the repositories you register as pills.
UPSTER_HOST_WORKSPACE=

# Dashboard listen port.
UPSTER_PORT=

# Host interface the dashboard port is published on.
# Defaults to 127.0.0.1 so the dashboard stays loopback-only.
# Set to 0.0.0.0 to expose it on the local network (only do this with auth enabled).
UPSTER_BIND_HOST=

# Directory where Upster stores its local data inside the container.
UPSTER_DATA_DIR=

# Comma separated container paths Upster is allowed to run pills from.
UPSTER_WORKSPACE_ROOTS=

# Comma separated allowlist of executables pills may run, matched exactly by
# bare name or full path. Leave empty to allow any executable.
# Example: bun,node,npm,pnpm,python3
UPSTER_ALLOWED_COMMANDS=

# Local app port range assigned to pills (min-max).
UPSTER_APP_PORT_RANGE=

# Local cloudflared metrics port range assigned to pills (min-max).
UPSTER_METRICS_PORT_RANGE=

# Public origin the dashboard is served from.
UPSTER_PUBLIC_ORIGIN=

# Force the Secure flag on the session cookie. Set to true when serving over
# HTTPS behind a proxy that does not forward the x-forwarded-proto header.
UPSTER_SECURE_COOKIES=

# Secret used to sign session cookies. Must be at least 16 characters.
# Leave empty to generate and persist one automatically.
UPSTER_SESSION_SECRET=

# libSQL connection string.
DATABASE_URL=

# libSQL auth. Generate a keypair and token with: bun run db:credentials
# SQLD_AUTH_JWT_KEY goes to the db service, DATABASE_AUTH_TOKEN to the dashboard.
# Leave both empty to run the database without authentication.
SQLD_AUTH_JWT_KEY=
DATABASE_AUTH_TOKEN=

# Path to the cloudflared binary.
CLOUDFLARED_BIN=
