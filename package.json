{
  "name": "upster",
  "private": true,
  "type": "module",
  "version": "0.0.7",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "UPSTER_DATA_DIR=${UPSTER_DATA_DIR:-$PWD/.upster} UPSTER_WORKSPACE_ROOTS=${UPSTER_WORKSPACE_ROOTS:-$PWD} bun run --cwd apps/web dev",
    "build": "bun run --cwd apps/web build",
    "preview": "UPSTER_DATA_DIR=${UPSTER_DATA_DIR:-$PWD/.upster} UPSTER_WORKSPACE_ROOTS=${UPSTER_WORKSPACE_ROOTS:-$PWD} bun run --cwd apps/web preview",
    "test": "bun run --cwd apps/web test",
    "lint": "bun run --cwd apps/web lint",
    "format": "prettier --write \"apps/web/**/*.{ts,tsx,js,jsx}\" \"scripts/**/*.ts\"",
    "check": "prettier --check \"apps/web/**/*.{ts,tsx,js,jsx}\" \"scripts/**/*.ts\"",
    "typecheck": "bun run --cwd apps/web typecheck && tsc --noEmit -p tsconfig.json",
    "validate": "bun run format && bun run lint && bun run typecheck && bun run test",
    "db:generate": "bun run --cwd apps/web db:generate",
    "db:migrate": "DATABASE_URL=${DATABASE_URL:-file:$PWD/.upster/upster.db} bun run --cwd apps/web db:migrate",
    "db:credentials": "bun run scripts/generate-db-credentials.ts"
  },
  "devDependencies": {
    "@types/node": "^22",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6"
  }
}
